# Required
NEO4J_URL=bolt://localhost:7687
NEO4J_PASS=           # Set a strong password. Default in docker-compose is "threadr123" — change in production.
REDIS_HOST=localhost
DB_PATH=./threadr.db

# API authentication (optional — leave empty to disable)
# Generate with: openssl rand -hex 32
API_TOKEN=

# Anonymous proxy (optional — routes all traffic through Tor)
# Start Tor: docker compose --profile tor up -d
# PROXY_ENABLED=true
# PROXY_PORTS=9051-9060

# Plugin API keys (optional — plugins without keys are skipped)
SHODAN_KEY=
VIRUSTOTAL_KEY=
HIBP_KEY=
SECURITYTRAILS_KEY=    # https://securitytrails.com/corp/api (free: 50 queries/month)
